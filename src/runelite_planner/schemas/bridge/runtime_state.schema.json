{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xptool://schemas/runtime_state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tick",
    "loginRuntimeActive",
    "logoutRuntimeActive",
    "motorProgramActive",
    "pendingMouseMove",
    "runtimeFlags"
  ],
  "properties": {
    "tick": {
      "type": "integer"
    },
    "loginRuntimeActive": {
      "type": "boolean"
    },
    "logoutRuntimeActive": {
      "type": "boolean"
    },
    "motorProgramActive": {
      "type": "boolean"
    },
    "pendingMouseMove": {
      "type": "boolean"
    },
    "runtimeFlags": {
      "type": "object"
    }
  }
}

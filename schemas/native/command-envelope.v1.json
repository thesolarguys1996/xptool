{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xptool/schemas/native/command-envelope.v1.json",
  "title": "CommandEnvelopeV1",
  "type": "object",
  "required": [
    "schemaVersion",
    "commandId",
    "commandType",
    "issuedAtUtc",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "commandType": {
      "type": "string",
      "minLength": 1
    },
    "issuedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "tokenId": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
